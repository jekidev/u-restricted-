# Required. One or more OpenRouter API keys, comma-separated.
OPENROUTER_API_KEYS=your-api-key-here

# Optional: comma-separated preferred models (overrides auto-discover)
OPENROUTER_MODELS=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=60
OPENROUTER_RETRIES=2
OPENROUTER_COOLDOWN=30
OPENROUTER_MAX_TOKENS=4000
OPENROUTER_TEMPERATURE=0.9
OPENROUTER_FREE_ONLY=true
OPENROUTER_AUTO_DISCOVER=true
OPENROUTER_MODEL_LIMIT=30
OPENROUTER_APP_NAME=OpenRouter Chat
# OPENROUTER_SITE_URL=https://your-domain.example
OPENROUTER_FAILURE_THRESHOLD=3

# Optional: protect /api/config, /api/conversations and /api/health/routes on public deploys
# ADMIN_TOKEN=your-random-secret

# Optional: encrypt the persistent conversation JSON file at rest (Fernet key derived from this string)
# CONVERSATION_ENCRYPTION_KEY=another-random-secret

# Optional: file path for persistent conversation storage (default: .cache/conversations.json)
# CONVERSATIONS_PATH=.cache/conversations.json

# Render / local port override
PORT=8000

# Required. Keep this server-side.
OPENROUTER_API_KEY=sk-or-v1-your-key

# Rotation settings
OPENROUTER_AUTO_DISCOVER=true
OPENROUTER_FREE_ONLY=true
OPENROUTER_MODEL_LIMIT=30
OPENROUTER_RETRIES=1
OPENROUTER_COOLDOWN=60
OPENROUTER_FAILURE_THRESHOLD=2
OPENROUTER_MAX_TOKENS=1400
OPENROUTER_APP_NAME=Rotation Chat
# OPENROUTER_SITE_URL=https://your-domain.example

# Optional fixed model order (comma-separated)
# OPENROUTER_MODELS=google/gemma-3-27b-it:free,meta-llama/llama-3.3-70b-instruct:free

# Multiple keys are supported, comma-separated
# OPENROUTER_API_KEYS=key-one,key-two
